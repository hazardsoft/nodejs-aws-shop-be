<?xml version='1.0' encoding='UTF-8' ?>
<?charles serialisation-version='2.0' ?>
<rewriteSet-array>
  <rewriteSet>
    <active>true</active>
    <name>Remove Authorization header</name>
    <hosts>
      <locationPatterns>
        <locationMatch>
          <location>
            <protocol>https</protocol>
            <host>8rk4roadt1.execute-api.eu-central-1.amazonaws.com</host>
            <port>443</port>
            <path>dev/import</path>
          </location>
          <enabled>true</enabled>
        </locationMatch>
      </locationPatterns>
    </hosts>
    <rules>
      <rewriteRule>
        <active>true</active>
        <ruleType>2</ruleType>
        <matchHeader>Authorization</matchHeader>
        <matchValue></matchValue>
